<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Explicitly block cleartext (HTTP) traffic for all domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow debug proxy tools (e.g. Charles, mitmproxy) in debug builds only -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
